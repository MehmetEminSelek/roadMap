# Mobile env dosyaları — Expo load sırası:
#   .env.${NODE_ENV}.local  (git'e eklenmez; kişisel override)
#   .env.local              (git'e eklenmez)
#   .env.${NODE_ENV}        (git'e eklenir: .env.development / .env.production)
#   .env                    (genel fallback — bu projede kullanılmıyor)
#
# `npx expo start`              → NODE_ENV=development → .env.development yüklenir
# `eas build` / `expo export`   → NODE_ENV=production  → .env.production yüklenir
#
# Fiziksel cihazla dev'de test ederken LAN IP gerekli (localhost çalışmaz):
#   ipconfig getifaddr en0

EXPO_PUBLIC_API_URL=http://192.168.1.100:3001
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
