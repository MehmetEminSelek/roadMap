# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/roadmap_db?schema=public"

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_API_URL=https://maps.googleapis.com/maps/api

# Google Gemini API
GOOGLE_GENERATIVE_AI_API_KEY=your_google_generative_ai_api_key_here

# JWT
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# Fuel Price (TL/Liter)
FUEL_PRICE_TL=28.5

# API Retry Config
API_MAX_RETRIES=3
API_BASE_DELAY_MS=1000
API_MAX_DELAY_MS=30000

# Rate Limiting (Google Maps API limits)
GOOGLE_MAPS_RATE_LIMIT=60

# TollGuru API (https://tollguru.com) — Turkey toll calculation
# Leave empty to disable; TollsService automatically falls back to local KGM seed data.
TOLLGURU_API_KEY=
# Provider strategy: tollguru | local | auto (default: auto → tollguru → local fallback)
TOLL_PROVIDER=auto

# Redis (optional cache layer)
REDIS_URL=redis://localhost:6379

# App
PORT=3001
NODE_ENV=development
